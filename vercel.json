{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/server.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/src/server.ts"
    },
    {
      "src": "/health",
      "dest": "backend/src/server.ts"
    }
  ],
  "functions": {
    "backend/src/server.ts": {
      "maxDuration": 10
    }
  }
}
